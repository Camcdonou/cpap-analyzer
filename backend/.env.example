# CPAP Analyzer Backend Configuration
# Copy this file to .env and fill in your values

# OpenAI-compatible API (required for AI features)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.synthetic.new/openai/v1
OPENAI_MODEL=hf:moonshotai/Kimi-K2.6

# Database (SQLite, created automatically)
DATABASE_URL=sqlite:///./cpap.db

# Upload directory (for zip uploads)
UPLOAD_DIR=./uploads
